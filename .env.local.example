# ──────────────────────────────────────────────────────────────
# Handshake AI — environment configuration
# Copy this file to .env.local and fill in your keys.
# The app runs end-to-end WITHOUT keys using built-in mock fallbacks.
# Add real keys to enable real ElevenLabs audio + LLM summaries.
# ──────────────────────────────────────────────────────────────

# ElevenLabs (text-to-speech for the AI voice agent)
ELEVENLABS_API_KEY=
# Optional: override the default voice. Default is "Rachel".
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Live Conversational AI (optional) ────────────────────────
# Set this to your ElevenLabs agent id to enable a REAL two-way in-browser
# voice call (Conversational AI) instead of the scripted simulation.
# Create the agent at elevenlabs.io → Conversational AI → Create agent.
# Leave blank to keep the simulated call. (The agent id is not a secret.)
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=

# Choose ONE LLM provider. If both are set, Anthropic is used first.
# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
